{
  "name": "tokenless-browser-session-bridge",
  "version": "0.1.0",
  "description": "Visible browser-session bridge extension and protocol for user-authorized web AI sessions.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": "./dist/src/index.js",
    "./protocol": "./dist/src/protocol.js",
    "./providers": "./dist/src/providers.js"
  },
  "files": [
    "dist/extension",
    "dist/src",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node dist/src/build-extension.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "pack:extension": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node dist/src/build-extension.mjs --zip",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
