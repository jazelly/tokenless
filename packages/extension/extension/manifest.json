{
  "manifest_version": 3,
  "key": "",
  "name": "Tokenless",
  "short_name": "Tokenless",
  "version": "0.1.5",
  "description": "Visible bridge for user-authorized ChatGPT, Claude, Gemini, and Grok web sessions.",
  "homepage_url": "https://github.com/jazelly/tokenless",
  "icons": {
    "16": "icons/tokenless-16.png",
    "32": "icons/tokenless-32.png",
    "48": "icons/tokenless-48.png",
    "128": "icons/tokenless-128.png"
  },
  "permissions": [
    "debugger",
    "nativeMessaging",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://grok.com/*"
      ],
      "js": [
        "content/provider-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "settings/index.html"
  },
  "action": {
    "default_title": "Open Tokenless settings",
    "default_icon": {
      "16": "icons/tokenless-16.png",
      "32": "icons/tokenless-32.png",
      "48": "icons/tokenless-48.png",
      "128": "icons/tokenless-128.png"
    }
  }
}
