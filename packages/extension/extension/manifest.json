{
  "manifest_version": 3,
  "name": "Tokenless",
  "version": "0.1.0",
  "description": "Visible bridge for user-authorized ChatGPT, Gemini, and Claude web sessions.",
  "permissions": [
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content/provider-content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "settings/index.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Open Tokenless settings"
  }
}
