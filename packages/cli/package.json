{
  "name": "tokenless",
  "version": "0.1.1",
  "description": "Tokenless CLI for visible-session browser automation.",
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "package.json"
  ],
  "bin": {
    "tokenless": "dist/src/tokenless.mjs"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22"
  }
}
