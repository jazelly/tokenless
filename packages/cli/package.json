{
  "name": "tokenless",
  "version": "0.2.0",
  "description": "Tokenless CLI for visible browser sessions and isolated direct provider APIs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jazelly/tokenless.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "package.json"
  ],
  "bin": {
    "tokenless": "dist/src/tokenless.mjs"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:native",
    "build:js": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/src/tokenless.mjs',0o755)\"",
    "build:native": "node scripts/build-rust-binaries.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build:js"
  },
  "dependencies": {
    "@tokenless/playwright": "0.1.0"
  },
  "optionalDependencies": {
    "tokenless-native-darwin-arm64": "0.2.0",
    "tokenless-native-darwin-x64": "0.2.0",
    "tokenless-native-linux-arm64": "0.2.0",
    "tokenless-native-linux-x64": "0.2.0",
    "tokenless-native-win32-arm64": "0.2.0",
    "tokenless-native-win32-x64": "0.2.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
