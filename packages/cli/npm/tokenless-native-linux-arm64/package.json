{
  "name": "tokenless-native-linux-arm64",
  "version": "0.2.0",
  "description": "Tokenless Rust runtime for linux-arm64.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jazelly/tokenless.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "os": [
    "linux"
  ],
  "cpu": [
    "arm64"
  ],
  "files": [
    "bin"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepack": "node ../../scripts/verify-native-package.mjs"
  },
  "tokenlessRuntime": {
    "protocol": "tokenless.native-package.v1",
    "platform": "linux",
    "arch": "arm64"
  },
  "engines": {
    "node": ">=22"
  }
}
