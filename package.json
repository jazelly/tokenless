{
  "name": "tokenless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Standalone managed Playwright bridge for visible AI provider sessions.",
  "scripts": {
    "build": "npm run build --workspaces --if-present && npm run build:scripts",
    "build:scripts": "node -e \"require('node:fs').rmSync('dist/scripts',{recursive:true,force:true})\" && tsc -p tsconfig.scripts.json",
    "changeset": "changeset",
    "lint": "npm run lint --workspaces --if-present && tsc -p tsconfig.scripts.json --noEmit",
    "release:version": "node scripts/release/version.mjs",
    "sync:skill": "npm run build:scripts && node dist/scripts/sync-tokenless-skill.mjs",
    "test": "npm run build && node dist/scripts/test-all.mjs",
    "test:e2e": "npm run build && TOKENLESS_E2E=1 node --test test/**/*.e2e.mjs",
    "test:e2e:live-managed-playwright-m1": "npm run build && node --test --test-concurrency=1 test/live-managed-playwright-prompt-actions.e2e.mjs",
    "test:e2e:live-managed-playwright": "npm run build && node --test --test-concurrency=1 test/live-managed-playwright.e2e.mjs"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "npm@10",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^26.1.1",
    "selfsigned": "^5.5.0",
    "typescript": "^7.0.2"
  }
}
